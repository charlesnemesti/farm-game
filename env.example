# ─── Solana network ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Optional: private RPC (recommended for mainnet — public RPC is rate-limited)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Treasury (fixed — same wallet as test phase) ────────────────────────────
NEXT_PUBLIC_TREASURY_PUBKEY=AXp2F7NP3cKU7nP8HXXL1XKuSrj1JeAYj2im4JKvNyvj

# Server signer for withdrawals — private key of NEXT_PUBLIC_TREASURY_PUBKEY
# Already set in Vercel from test — DO NOT rotate at launch unless you migrate funds.
# JSON byte array from `npm run generate-treasury`, or base64 64-byte secret.
# TREASURY_SECRET_KEY=

# ─── Launch (one command when you have the pump.fun CA) ───────────────────────
# Pre-launch: do NOT set NEXT_PUBLIC_WALLET_MODE_ENABLED (wallet mode stays closed).
#             delete or leave empty any NEXT_PUBLIC_CORN_MINT in Vercel.
# At launch:  npm run launch -- <OFFICIAL_PUMP_FUN_MINT_CA>
#              → paste ALL printed vars into Vercel Production → redeploy
#              → includes NEXT_PUBLIC_WALLET_MODE_ENABLED=true
# NEXT_PUBLIC_WALLET_MODE_ENABLED=true
# NEXT_PUBLIC_CORN_MINT=
NEXT_PUBLIC_CORN_DECIMALS=6
NEXT_PUBLIC_CORN_TOKEN_PROGRAM=token-2022

# ─── Persistent saves (survives Vercel redeploys) ─────────────────────────────
# Vercel Dashboard → corn-farm → Storage → connect corn-farm-blob to project
# BLOB_STORE_ID=  (auto-added when Blob is connected)

# Local: vercel env pull .env.local
# Health: GET /api/health/storage → { "backend": "blob" }
# Launch: GET /api/treasury/status → readyForDeposits + readyForWithdrawals
