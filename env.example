# Mainnet test — pump.fun token "test"
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Treasury wallet (deposits in, withdrawals out)
NEXT_PUBLIC_TREASURY_PUBKEY=AXp2F7NP3cKU7nP8HXXL1XKuSrj1JeAYj2im4JKvNyvj

# pump.fun test token mint CA
NEXT_PUBLIC_CORN_MINT=6khn5QcnwHHaeURKEwAAHdS3LxnVpEbiWvfDLfToFGSc
NEXT_PUBLIC_CORN_DECIMALS=6
NEXT_PUBLIC_CORN_TOKEN_PROGRAM=token-2022

# Server signer for withdrawals — private key of NEXT_PUBLIC_TREASURY_PUBKEY
# JSON byte array from `npm run generate-treasury`, or base64 64-byte secret.
# Required for withdrawals (local .env.local + Vercel env vars). NEVER commit real keys.
# TREASURY_SECRET_KEY=

# Optional: private RPC (recommended for mainnet)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Persistent saves (survives Vercel redeploys) ─────────────────────────────
# Vercel Dashboard → corn-farm → Storage → Create Blob Store → Connect to project
# Vercel auto-adds BLOB_READ_WRITE_TOKEN. Without it, saves use ephemeral .data/ only.
# BLOB_READ_WRITE_TOKEN=

# After connecting Blob locally: vercel env pull .env.local
# Optional one-time migration from local .data/: npm run migrate-to-blob
# Health check in prod: GET /api/health/storage → { "backend": "blob" }
